rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasAllowedRole() {
      return signedIn()
        && request.auth.token.role in ['admin', 'fire', 'medical', 'police', 'attendee'];
    }

    function isStaff() {
      return signedIn()
        && request.auth.token.role in ['admin', 'fire', 'medical', 'police'];
    }

    function alertPayloadIsSafe() {
      return request.resource.data.keys().hasOnly([
        'type', 'location', 'status', 'teams', 'message', 'severity', 'timestamp'
      ])
      && request.resource.data.type is string
      && request.resource.data.location is string
      && request.resource.data.status in ['pending', 'approved', 'dispatched', 'resolved']
      && request.resource.data.teams is list
      && request.resource.data.message is string
      && request.resource.data.severity in ['low', 'medium', 'high'];
    }

    match /alerts/{alertId} {
      allow read: if hasAllowedRole();

      allow create: if hasAllowedRole() && alertPayloadIsSafe();

      allow update: if isStaff()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status', 'assignedTeams', 'message', 'severity'
        ]);

      allow delete: if signedIn() && request.auth.token.role == 'admin';
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
